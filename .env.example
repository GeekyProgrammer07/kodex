# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Bun always loads .env from the repo root unconditionally.
# All turbo-spawned processes (chat-service, web, etc.) inherit these vars.
# NODE_ENV is set per-command in package.json scripts and controls runtime
# behaviour (log format, Prisma log level) — secrets live here in .env only.
# In production, set these vars via your deployment platform (Railway, Fly, etc.)

# ─── Database ─────────────────────────────────────────────────────────────────
# Shared Postgres for all services — managed via packages/db with Prisma
# Matches the docker-compose.yml defaults:
DATABASE_URL=postgresql://kodex:kodex_dev@localhost:5432/liveCode_dev

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Must be the same value across all services that verify JWTs
JWT_SECRET=change-me-use-a-long-random-string

# ─── Service Ports ────────────────────────────────────────────────────────────
PORT=3001          # apps/chat-service

# ─── Inter-service URLs ───────────────────────────────────────────────────────
CHAT_SERVICE_URL=http://localhost:3001
