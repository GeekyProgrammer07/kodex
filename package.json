{
  "name": "kodex",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development turbo run dev",
    "build": "NODE_ENV=production turbo run build",
    "start": "NODE_ENV=production turbo run start",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "NODE_ENV=development turbo run db:generate --filter=@kodex/db",
    "db:push": "NODE_ENV=development turbo run db:push --filter=@kodex/db"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.0",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "pino-pretty": "^13.1.3"
  }
}
